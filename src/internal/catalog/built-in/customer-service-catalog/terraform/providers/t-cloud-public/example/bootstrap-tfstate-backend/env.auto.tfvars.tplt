bucket_name = "bucket-tf-{{ .cluster.name }}-{{ .cluster.stage }}"
user_name   = "tfstate-{{ .cluster.name }}-{{ .cluster.stage }}"

enable_bucket_server_side_encryption = true
bucket_kms_pending_days              = 7

# Set create_obs_kms_agency = false if the tenant already has the OBSAccessKMS
# agency (or an equivalent op_svc_obs agency with KMS access).
create_obs_kms_agency        = true
obs_kms_agency_name          = "OBSAccessKMS"
obs_kms_agency_project_roles = ["KMS Administrator"]
