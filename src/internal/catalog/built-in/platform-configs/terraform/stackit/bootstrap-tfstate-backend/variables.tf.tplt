variable "project_id" {
  description = "STACKIT project ID"
  type        = string
}

variable "credentials_group_name" {
  description = "STACKIT credentials group name: you can assign any name"
  type        = string
}

variable "bucket_name" {
  description = "STACKIT bucket name: you can use any name that has not been used globally for buckets"
  type        = string
}
